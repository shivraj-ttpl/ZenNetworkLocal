# ============================================================
# LOCAL DEVELOPMENT — Proxy mode (recommended)
# Cookies work, no CORS issues, no ngrok needed
# ============================================================
VITE_API_URL="/api/v1"
VITE_PROXY_TARGET="http://192.168.0.144:5000"

# --- Alternative local IPs (uncomment one if needed) ---
# VITE_PROXY_TARGET="http://172.20.10.2:5000"
# VITE_PROXY_TARGET="http://192.168.0.51:5000"

# ============================================================
# LOCAL DEV — Direct to ngrok (no proxy, cross-origin)
# Uncomment these and comment out the proxy lines above
# ============================================================
# VITE_API_URL="https://a11a-49-248-29-250.ngrok-free.app/api/v1"
# VITE_PROXY_TARGET=

# ============================================================
# LOCAL DEV — Direct to production backend (for testing)
# Uncomment these and comment out the proxy lines above
# ============================================================
# VITE_API_URL="/api/v1"
# VITE_PROXY_TARGET="https://api.zanenetwork.com"

# ============================================================
# PRODUCTION BUILD — Send this to DevOps
# No proxy needed (proxy only works in Vite dev server)
# Set this in CI/CD build environment or .env.production
# ============================================================
# VITE_API_URL="https://api.zanenetwork.com/api/v1"
